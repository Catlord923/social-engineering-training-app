<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="1080.0" maxWidth="1440.0" minHeight="1080.0" minWidth="1440.0"
            prefHeight="1080.0" prefWidth="1440.0"
            style="-fx-background-color: #0f172a;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.ScenarioController">
   <children>

      <!-- Header band -->
      <AnchorPane prefHeight="110.0"
                  style="-fx-background-color: #1e293b; -fx-border-color: transparent transparent #334155 transparent; -fx-border-width: 0 0 1 0;"
                  AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <!-- Module label -->
            <Label text="SCENARIO"
                   style="-fx-font-size: 11px; -fx-text-fill: #3b82f6; -fx-font-weight: bold;"
                   AnchorPane.topAnchor="22.0" AnchorPane.leftAnchor="60.0" />

            <!-- Scenario title -->
            <Label fx:id="titleLabel" alignment="TOP_LEFT" wrapText="true"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"
                   AnchorPane.topAnchor="40.0" AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="220.0" />

            <!-- Progress badge -->
            <Label fx:id="progressLabel" alignment="CENTER"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-background-color: #0f172a; -fx-background-radius: 20; -fx-padding: 6 14 6 14;"
                   AnchorPane.topAnchor="38.0" AnchorPane.rightAnchor="60.0" />
         </children>
      </AnchorPane>

      <!-- Prompt label -->
      <Label fx:id="promptLabel" alignment="TOP_LEFT" wrapText="true"
             style="-fx-font-size: 19px; -fx-text-fill: #94a3b8; -fx-padding: 18 60 10 60;"
             AnchorPane.topAnchor="110.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

      <!-- Scrollable scenario content -->
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                  style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                  AnchorPane.topAnchor="175.0" AnchorPane.bottomAnchor="220.0"
                  AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0">
         <content>
            <VBox fx:id="contentContainer" spacing="16.0" style="-fx-padding: 4 4 20 4;" />
         </content>
      </ScrollPane>

      <!-- Options area -->
      <AnchorPane prefHeight="1.0"
                  style="-fx-background-color: #334155;"
                  AnchorPane.bottomAnchor="218.0"
                  AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0" />

      <VBox fx:id="optionsContainer" spacing="10.0"
            style="-fx-padding: 16 60 20 60;"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
            prefHeight="218.0" />

   </children>
</AnchorPane>
