<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="1080.0" maxWidth="1440.0" minHeight="1080.0" minWidth="1440.0" prefHeight="1080.0" prefWidth="1440.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.WelcomeController">
   <children>

      <!-- Title — identical anchor constraints to TheoryScreen titleLabel -->
      <Label alignment="CENTER" text="Social Engineering Awareness" textAlignment="CENTER" wrapText="true"
             AnchorPane.topAnchor="100.0" AnchorPane.bottomAnchor="920.0"
             AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0">
         <font>
            <Font size="24.0" />
         </font>
      </Label>

      <!-- Body — sits in the same region as TheoryScreen's ScrollPane/bodyContainer -->
      <VBox fx:id="bodyContainer" alignment="TOP_LEFT" fillWidth="true" spacing="18.0" style="-fx-padding: 30;"
            AnchorPane.topAnchor="215.0" AnchorPane.bottomAnchor="125.0"
            AnchorPane.leftAnchor="160.0" AnchorPane.rightAnchor="160.0">
      </VBox>

      <!-- Start button — centred in the same footer band as the theory navigation buttons -->
      <Button fx:id="startButton" text="Start" mnemonicParsing="false" onAction="#handleStartButton"
              prefHeight="45.0" prefWidth="120.0"
              AnchorPane.bottomAnchor="80.0" AnchorPane.topAnchor="955.0"
              AnchorPane.leftAnchor="660.0" AnchorPane.rightAnchor="660.0">
         <font>
            <Font size="16.0" />
         </font>
      </Button>

   </children>
</AnchorPane>
