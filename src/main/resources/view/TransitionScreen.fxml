<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="1080.0" maxWidth="1440.0" minHeight="1080.0" minWidth="1440.0"
            prefHeight="1080.0" prefWidth="1440.0"
            style="-fx-background-color: #0f172a;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.TransitionController">
   <children>

      <!-- Centred card -->
      <VBox alignment="CENTER" spacing="0.0"
            style="-fx-background-color: #1e293b; -fx-background-radius: 16; -fx-padding: 60 70 60 70;"
            AnchorPane.topAnchor="160.0" AnchorPane.bottomAnchor="160.0"
            AnchorPane.leftAnchor="300.0" AnchorPane.rightAnchor="300.0">

         <!-- Icon badge -->
         <Label text="▶" style="-fx-font-size: 28px; -fx-text-fill: #3b82f6; -fx-padding: 0 0 24 0;" />

         <!-- Title -->
         <Label fx:id="titleLabel" alignment="CENTER" textAlignment="CENTER" wrapText="true"
                style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9; -fx-padding: 0 0 28 0;" />

         <!-- Divider -->
         <AnchorPane prefHeight="2.0" prefWidth="80.0"
                     style="-fx-background-color: #3b82f6; -fx-background-radius: 2;" />

         <!-- Body paragraphs -->
         <VBox fx:id="bodyContainer" alignment="TOP_CENTER" fillWidth="true" spacing="16.0"
               style="-fx-padding: 32 0 40 0;" />

         <!-- CTA button -->
         <Button fx:id="continueButton" mnemonicParsing="false" onAction="#handleContinueButton"
                 text="Continue"
                 prefHeight="52.0" prefWidth="240.0"
                 style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" />

      </VBox>

   </children>
</AnchorPane>
