<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="1080.0" maxWidth="1440.0" minHeight="1080.0" minWidth="1440.0"
            prefHeight="1080.0" prefWidth="1440.0"
            style="-fx-background-color: #0f172a;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.ResultsController">
    <children>

        <!-- Module label -->
        <Label text="RESULTS"
               style="-fx-font-size: 11px; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-letter-spacing: 3;"
               AnchorPane.topAnchor="56.0" AnchorPane.leftAnchor="180.0" />

        <!-- Page title -->
        <Label text="Your Results" alignment="TOP_LEFT" wrapText="true"
               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"
               AnchorPane.topAnchor="85.0" AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0"
               prefHeight="52.0" />

        <!-- Divider -->
        <AnchorPane prefHeight="2.0"
                    style="-fx-background-color: #1e293b;"
                    AnchorPane.topAnchor="155.0"
                    AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0" />

        <!-- Scrollable content - bottomAnchor leaves room for the footer -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                    AnchorPane.topAnchor="175.0" AnchorPane.bottomAnchor="100.0"
                    AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0">
            <content>
                <VBox spacing="32.0" style="-fx-padding: 10 10 40 10;">

                    <!-- Scenarios section -->
                    <VBox spacing="12.0">
                        <Label text="Practice Scenarios"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-letter-spacing: 1;" />
                        <Label text="Your choices across the scenarios."
                               style="-fx-font-size: 16px; -fx-text-fill: #94a3b8;" />
                        <VBox fx:id="scenarioBreakdownContainer" spacing="8.0" />
                    </VBox>

                    <!-- Bonus section -->
                    <VBox spacing="12.0">
                        <Label text="Bonus Scenario"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-letter-spacing: 1;" />
                        <Label text="Did you spot and avoid the phishing registration form?"
                               style="-fx-font-size: 16px; -fx-text-fill: #94a3b8;" />
                        <VBox fx:id="bonusBreakdownContainer" spacing="8.0" />
                    </VBox>

                    <!-- Quiz section -->
                    <VBox spacing="12.0">
                        <Label text="Knowledge Quiz"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-letter-spacing: 1;" />
                        <Label text="Your score on the multiple-choice knowledge check."
                               style="-fx-font-size: 16px; -fx-text-fill: #94a3b8;" />
                        <VBox fx:id="quizBreakdownContainer" spacing="8.0" />
                    </VBox>

                    <!-- Overall message -->
                    <VBox spacing="12.0"
                          style="-fx-background-color: #1e293b; -fx-background-radius: 10; -fx-padding: 24 28 24 28;">
                        <Label text="Overall"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-letter-spacing: 1;" />
                        <VBox fx:id="overallMessageContainer" spacing="0.0" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>

        <!-- Footer divider -->
        <AnchorPane prefHeight="1.0"
                    style="-fx-background-color: #1e293b;"
                    AnchorPane.bottomAnchor="99.0"
                    AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0" />

        <!-- Exit button -->
        <Button mnemonicParsing="false" onAction="#handleExit"
                text="Exit"
                prefHeight="46.0" prefWidth="140.0"
                style="-fx-background-color: #1e293b; -fx-text-fill: #94a3b8; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #334155; -fx-border-radius: 8; -fx-cursor: hand;"
                AnchorPane.bottomAnchor="38.0" AnchorPane.rightAnchor="180.0" />

    </children>
</AnchorPane>
