<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="1080.0" maxWidth="1440.0" minHeight="1080.0" minWidth="1440.0"
            prefHeight="1080.0" prefWidth="1440.0"
            style="-fx-background-color: #0f172a;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.TheoryController">
   <children>

      <!-- Module label -->
      <Label text="THEORY"
             style="-fx-font-size: 11px; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-letter-spacing: 3;"
             AnchorPane.topAnchor="56.0" AnchorPane.leftAnchor="180.0" />

      <!-- Page title -->
      <Label fx:id="titleLabel" alignment="TOP_LEFT" textAlignment="LEFT" wrapText="true"
             style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;"
             AnchorPane.topAnchor="85.0" AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0"
             prefHeight="100.0" />

      <!-- Divider -->
      <AnchorPane prefHeight="2.0"
                  style="-fx-background-color: #1e293b;"
                  AnchorPane.topAnchor="205.0"
                  AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0" />

      <!-- Scrollable body -->
      <ScrollPane fx:id="bodyScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                  style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                  AnchorPane.topAnchor="220.0" AnchorPane.bottomAnchor="130.0"
                  AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0">
         <content>
            <VBox fx:id="bodyContainer" alignment="TOP_LEFT" fillWidth="true" spacing="20.0"
                  style="-fx-padding: 10 10 30 10;" />
         </content>
      </ScrollPane>

      <!-- Footer divider -->
      <AnchorPane prefHeight="1.0"
                  style="-fx-background-color: #1e293b;"
                  AnchorPane.bottomAnchor="129.0"
                  AnchorPane.leftAnchor="180.0" AnchorPane.rightAnchor="180.0" />

      <!-- Previous button -->
      <Button fx:id="previousButton" mnemonicParsing="false" onAction="#handlePrevious"
              text="← Previous"
              prefHeight="46.0" prefWidth="160.0"
              style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 15px; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"
              AnchorPane.bottomAnchor="70.0" AnchorPane.leftAnchor="180.0" />

      <!-- Page indicator -->
      <Label fx:id="pageIndicatorLabel" alignment="CENTER" textAlignment="CENTER"
             style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: bold;"
             prefWidth="100.0"
             AnchorPane.bottomAnchor="83.0" AnchorPane.leftAnchor="660.0" AnchorPane.rightAnchor="660.0" />

      <!-- Next button -->
      <Button fx:id="nextButton" mnemonicParsing="false" onAction="#handleNext"
              text="Next →"
              prefHeight="46.0" prefWidth="160.0"
              style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
              AnchorPane.bottomAnchor="70.0" AnchorPane.rightAnchor="180.0" />

   </children>
</AnchorPane>
